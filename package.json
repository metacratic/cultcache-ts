{
  "name": "cultcache-ts",
  "version": "0.1.0",
  "description": "CultCache-style typed persistence for TypeScript with schema-backed polymorphic MessagePack storage.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  },
  "keywords": [
    "messagepack",
    "schema",
    "cache",
    "persistence",
    "zod",
    "typescript"
  ],
  "author": "metacratic",
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
