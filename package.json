{
  "name": "cultcache-ts",
  "version": "0.13.1",
  "description": "CultCache-style typed persistence for TypeScript with schema-backed polymorphic MessagePack storage.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:inspector": "tsc -p tsconfig.inspector.json && vite build --config vite.inspector.config.ts",
    "dev:inspector": "concurrently -k \"vite --host 127.0.0.1 --config vite.inspector.config.ts\" \"wait-on http://127.0.0.1:5173 && cross-env CULTCACHE_INSPECTOR_DEV_SERVER=http://127.0.0.1:5173 electron electron/main.cjs\"",
    "dist:inspector": "npm run build:inspector && electron-builder --config electron-builder.json",
    "pack:inspector": "npm run build:inspector && electron-builder --config electron-builder.json --dir",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist-test/test/cult-cache.test.js"
  },
  "keywords": [
    "messagepack",
    "schema",
    "cache",
    "persistence",
    "zod",
    "typescript"
  ],
  "author": "metacratic",
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@epiphanygraph/epiphany-graph-viewer": "file:../EpiphanyGraph/web/epiphany-graph-viewer",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.9.0",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  }
}
