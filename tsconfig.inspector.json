{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": ".",
    "types": ["vite/client"]
  },
  "include": [
    "inspector/src/**/*.ts",
    "inspector/src/**/*.tsx",
    "src/cult-cache-inspector.ts"
  ]
}
